# Node / npm: deps live here, downloaded by `npm install`. Never committed.
node_modules/

# Build output: regenerated by `npm run build`. Never committed.
dist/

# Jest coverage reports.
coverage/

# clasp's local config (your personal Apps Script project ID).
# Use .clasp.json.example as the template; copy it to .clasp.json locally
# and fill in your own scriptId. The real .clasp.json must NOT be committed
# because it points at a specific Apps Script project that's not part of the repo.
.clasp.json

# Logs and editor scratch files.
*.log
.DS_Store

# Environment / secret files (if we ever add any locally for testing).
.env
.env.local

# Roster CSV exports. These contain member callsign + name PII; we do not
# want a `git add -A` to accidentally commit them. Slice 2 populates the
# Roster Sheet tab by hand; Slice 3's Sunday-Sync will read from a Drive CSV
# (out-of-repo) and write to the Sheet, so the CSV should never live here.
members-*.csv
